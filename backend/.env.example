# Server Configuration
PORT=5002
NODE_ENV=development

# LinkedIn Automation Settings
LINKEDIN_USERNAME=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# Email Dispatcher Settings (Gmail SMTP using App Password)
# NOTE: Set up an App Password in Google Account -> Security -> 2-Step Verification -> App passwords
GMAIL_USER=your_gmail_username@gmail.com
GMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# CC Recipients (comma-separated list)
CC_EMAILS=quinn@jpitstaffing.com,kim@jpitstaffing.com

# Optional: Gemini API Key for AI Resume Tailoring
GEMINI_API_KEY=your_gemini_api_key_here
